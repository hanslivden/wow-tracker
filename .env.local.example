# Discord Webhook URL
# Create one in your Discord server: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Cron secret (used to authenticate cron job endpoint)
CRON_SECRET=change-this-to-a-random-secret

# Optional: Raider.io API key (not required for public data)
# RAIDERIO_API_KEY=
